{
  "version": 2,
  "buildCommand": "npm run build",
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/js/firebase-config.js",
      "dest": "server.js"
    },
    {
      "src": "/xpanel/?",
      "dest": "server.js"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
